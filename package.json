{
    "name": "verilog-testbench-instance",
    "displayName": "Verilog_Testbench",
    "description": "verilog-testbench-instance",
    "version": "0.0.5",
    "publisher": "Truecrab",
    "engines": {
        "vscode": "^1.23.0"
    },
    "categories": [
        "Other"
    ],
    "activationEvents": [
        "onCommand:extension.instance",
        "onCommand:extension.testbench"
    ],
    "main": "./out/extension",
    "contributes": {
        "commands": [
            {
                "command": "extension.instance",
                "title": "Instance"
            },
            {
                "command": "extension.testbench",
                "title": "Testbench"
            }
        ]
    },
    "icon": "verilog.png",
    "keywords": [
        "Verilog",
        "Testbench",
        "Instance"
    ],
    "scripts": {
        "vscode:prepublish": "npm run compile",
        "compile": "tsc -p ./",
        "watch": "tsc -watch -p ./",
        "test": "npm run compile && node ./out/test/index"
    },
    "devDependencies": {
        "@types/glob": "^7.1.0",
        "@types/mocha": "^5.2.0",
        "@types/node": "^16.0.0",
        "@types/vscode": "^1.23.0",
        "glob": "^7.1.2",
        "mocha": "^5.2.0",
        "tslint": "^5.8.0",
        "typescript": "^4.9.0"
    },
    "dependencies": {
        "iconv-lite": "^0.7.2"
    }
}
